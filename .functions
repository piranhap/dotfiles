#############################################
# PROMPT UTILITY FUNCTIONS
#############################################

__prompt_ip() {
    ip route get 1.1.1.1 2>/dev/null | awk -F 'src ' 'NR==1{print $2}' | awk '{print $1}'
}

__prompt_git() {
    local branch
    branch=$(git rev-parse --abbrev-ref HEAD 2>/dev/null)
    [[ -n $branch ]] && printf " (git:%s)" "$branch"
}

__prompt_bar() {
    printf "%*s" "$(tput cols)" "" | tr ' ' '─'
}

